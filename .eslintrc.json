{
  "env": {
    "browser": true,
    "es2021": true,
    "jasmine": true
  },
  "extends": [
    "eslint-config-airbnb-base",
    "plugin:@typescript-eslint/recommended",
    "plugin:prettier/recommended",
    "prettier",
    "eslint:recommended",
    "plugin:prettier/recommended"
  ],
  "overrides": [
    {
      "files": ["tests/**/*"],
      "plugins": ["jest"],
      "globals": {
        "jest": true
      }
    }
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint", "prettier"],
  "rules": {
    "consistent-return": "off",
    "no-param-reassign": "off",
    "func-names": "off",
    "no-underscore-dangle": "off",
    "import/no-mutable-exports": "off",
    "class-methods-use-this": "off",
    "prefer-destructuring": ["error", { "object": true, "array": false }],
    "no-unused-vars": ["error", { 
    "argsIgnorePattern": "req|res|next|val",
     "varsIgnorePattern": "req|res|next|val" 
     }],
    "no-shadow": ["error", { "ignoreOnInitialization": true }],
    "import/no-unresolved": ["error", { "commonjs": true, "amd": true }], "import/extensions": [
      "error",
      "ignorePackages",
      {
        "js": "never",
        "ts": "never",
         "json": "always"
      }
    ],
    "import/no-extraneous-dependencies": [
      "error",
      {
        "devDependencies": true,
        "optionalDependencies": false,
        "peerDependencies": false,

        "packageDir": "./"
      }
    ],
    "import/extensions": [
      "error", // <severity>: "off", "warn", "error"
      "never", // default for all extensions
      {
        "js": "never",   // specific override per extension
        "ts": "never",
        "json": "always"
      }
    ],
  },
  "settings": {
    "import/resolver": {
      "node": {
        "extensions": [".js", ".ts"],
        "paths": ["./"],
        "moduleDirectory": ["node_modules", "src"]
      }
    }
  }
}
