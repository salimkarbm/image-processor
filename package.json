{
    "name": "starter",
    "version": "1.0.0",
    "description": "project starter",
    "main": "dist/app.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/app.js",
        "postinstall": "tsc",
        "watch": "nodemon --exec  ts-node src/app.ts",
        "lint": "eslint --ext .ts . --fix",
        "format": "npm run prettier && npm run lint",
        "prettier": "prettier --config .prettierrc --ignore-path .gitignore  --write './src/**/*.+(js|ts)'",
        "start:dev": "npm run tsc && nodemon  ./src/app.ts",
        "start:prod": "npm run tsc && NODE_ENV=production nodemon ./src/app.js",
        "tsc": "tsc",
        "clean": "rm -rf dist",
        "type-check": "tsc --noEmit",
        "test": "jest --detectOpenHandles",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "migration:generate": "npm run typeorm -- migration:generate -d src/config/db.config.ts",
        "migration:run": "npm run typeorm -- migration:run -d src/config/db.config.ts",
        "migration:revert": "npm run typeorm -- migration:revert -d src/config/db.config.ts",
        "migration:create": "npm run typeorm -- migration:create -d src/config/db.config.ts"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/salimkarbm/starter.git"
    },
    "author": "salim imuzai",
    "license": "ISC",
    "keywords": [
        "api",
        "security",
        "express",
        "authentication",
        "authorization",
        "jwt",
        "bcrypt",
        "helmet",
        "cors",
        "validation",
        "sanitization",
        "xss",
        "nodejs",
        "typescript"
    ],
    "bugs": {
        "url": "https://github.com/salimkarbm/starter/issues"
    },
    "homepage": "https://github.com/salimkarbm/starter#readme",
    "dependencies": {
        "@types/bcrypt": "^6.0.0",
        "@types/compression": "^1.8.1",
        "@types/swagger-jsdoc": "^6.0.4",
        "@types/swagger-ui-express": "^4.1.8",
        "@types/validator": "^13.15.10",
        "bcrypt": "^6.0.0",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^16.1.4",
        "express": "^4.18.2",
        "express-rate-limit": "^8.2.1",
        "helmet": "^8.1.0",
        "pg": "^8.16.3",
        "reflect-metadata": "^0.2.2",
        "save-dev": "^0.0.1-security",
        "supertest": "^7.2.2",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typeorm": "^0.3.27",
        "validator": "^13.15.23",
        "xss": "^1.0.15",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@jest/globals": "^30.3.0",
        "@types/cors": "^2.8.13",
        "@types/express": "^4.17.17",
        "@types/jest": "^30.0.0",
        "@types/node": "^17.0.13",
        "@types/supertest": "^7.2.0",
        "@typescript-eslint/eslint-plugin": "^5.12.0",
        "@typescript-eslint/parser": "^5.12.0",
        "eslint": "^8.8.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-import": "^2.25.4",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-prettier": "^5.5.4",
        "jest": "^30.3.0",
        "nodemon": "^2.0.15",
        "prettier": "^3.6.2",
        "ts-jest": "^29.4.9"
    },
    "engines": {
        "node": ">=16.0.0",
        "npm": ">=8.0.0"
    }
}
